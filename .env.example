# Copy to .env on the machine that runs Docker (e.g. your web server).
# Never commit .env — it is gitignored.
#
# Used by docker compose variable substitution and passed into the app container.

NODE_ENV=production
PLANNER_PASSWORD=use-a-long-random-password
PLANNER_SESSION_SECRET=another-long-random-string-different-from-password

# Optional: same values work if you run node without Docker
# PORT=3080
# DATA_DIR=./data
